    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "konva": "^10.2.0",
    "next": "16.1.6",
    "openai": "^6.25.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-konva": "^19.2.2",
    "resend": "^6.9.3",
    "stripe": "^20.4.0",
    "tailwind-merge": "^3.5.0",
    "twilio": "^5.12.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
